# AWS (VoiceStream account, us-east-2)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-2
SMM_CEO_S3_BUCKET=smm-ceo-applications

# SendGrid
SENDGRID_API_KEY=
SMM_MAGIC_LINK_FROM_EMAIL=stan@sharemymeals.org
SMM_MAGIC_LINK_FROM_NAME=Stan Berteloot

# Cloudflare Turnstile
# Dev: use Cloudflare test keys (always pass)
#   TURNSTILE_SITE_KEY=1x00000000000000000000AA
#   TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
# Prod: create real keys at dash.cloudflare.com -> Turnstile, bound to the Netlify domain
TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# HMAC secret for signing magic-link tokens. Generate once:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SMM_TOKEN_SECRET=

# Public site URL (used to build magic links in outgoing emails)
# Dev: http://localhost:8888
# Prod: https://your-netlify-subdomain.netlify.app (or custom domain)
SMM_SITE_URL=http://localhost:8888

# Optional: Telegram ping on new submission
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
